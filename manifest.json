{
  "manifest_version": 3,
  "name": "Quick Copy",
  "version": "1.0.0",
  "description": "Copy selected text instantly from the right-click menu.",
  "permissions": ["contextMenus", "scripting", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Quick Copy",
    "default_popup": "popup.html"
  }
}
